
package student;


public class Student {

  int id;
    String name;
    double cgpa;
    void Input(int a, String b, double c){
        id=a;
        name=b;
        cgpa=c;
    }
    void display(){
        System.out.println("ID"+id);
        System.out.println("NAME"+name);
        System.out.println("CGPA"+cgpa);
    }
    public static void main(String[] args) {
        Student asraful=new Student();
        asraful.Input(1019, "Asraful", 3.40);
        asraful.display();
    }
}
